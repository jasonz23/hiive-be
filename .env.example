# --- Database (matches docker-compose: pgvector on host port 5433) ---
DATABASE_URL="postgresql://hiive:hiive@localhost:55432/hiive?schema=public"

# --- Redis (matches docker-compose: host port 6380) ---
REDIS_URL="redis://localhost:63799"

# --- Server ---
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
CORS_ALLOW_LIST="http://localhost:3000"

# --- LLM (optional) ---
# Leave OPENAI_API_KEY empty to use the deterministic MockProvider (no key required).
# Set it to use real OpenAI for chat + embeddings.
OPENAI_API_KEY=""
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Embedding vector dimension. Mock + text-embedding-3-small both use 1536.
EMBEDDING_DIM=1536
